CURATOR_DATA_DIR=./data
CURATOR_BASE_URL=http://localhost:3000
# Comma-separated browser origins accepted by Better Auth.
CURATOR_TRUSTED_ORIGINS=http://localhost:3000
# Comma-separated hostnames/IPs allowed to load Next.js development assets.
CURATOR_ALLOWED_DEV_ORIGINS=localhost,127.0.0.1
# Optional deployment override. Normal local installations generate a secret file.
BETTER_AUTH_SECRET=
